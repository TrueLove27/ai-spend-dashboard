# Cloud Spend Dashboard — environment variables
# Copy this file to .env and fill in optional keys.

# SQLite by default. For PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/spend_dashboard

# Display currency for converted totals (fetched live via Frankfurter API)
DISPLAY_CURRENCY=EUR

# Optional: Stripe TEST secret key (sk_test_...) enables live billing sync
# STRIPE_SECRET_KEY=sk_test_your_key_here
